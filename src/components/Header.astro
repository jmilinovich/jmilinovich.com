---
import Logo from './Logo.astro';
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/writing', label: 'Writing' },
  { href: '/talks', label: 'Talks' },
  { href: '/projects', label: 'Projects' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <a href="/" class="logo" aria-label="Home">
      <Logo />
    </a>
    <nav class="nav" aria-label="Main">
      {navLinks.map((link) => (
        <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
          {link.label}
        </a>
      ))}
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </nav>
  </div>
</header>

<script>
  function setupHeader() {
    // ── Theme toggle ──
    function handleToggle(event: MouseEvent) {
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

      if (
        !document.startViewTransition ||
        window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        return;
      }

      const x = event.clientX;
      const y = event.clientY;

      const transition = document.startViewTransition(() => {
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
      });

      transition.ready.then(() => {
        const right = window.innerWidth - x;
        const bottom = window.innerHeight - y;
        const maxRadius = Math.hypot(
          Math.max(x, right),
          Math.max(y, bottom)
        );

        document.documentElement.animate(
          {
            clipPath: [
              `circle(0px at ${x}px ${y}px)`,
              `circle(${maxRadius}px at ${x}px ${y}px)`,
            ],
          },
          {
            duration: 500,
            easing: 'ease-in-out',
            pseudoElement: '::view-transition-new(root)',
          }
        );
      });
    }

    document.getElementById('theme-toggle')?.addEventListener('click', handleToggle);

    // ── Scroll show/hide (mobile only) ──
    const header = document.getElementById('site-header');
    if (!header) return;

    let lastScrollY = 0;
    let ticking = false;
    const THRESHOLD = 8;

    function onScroll() {
      if (ticking) return;
      ticking = true;

      requestAnimationFrame(() => {
        // Only apply scroll behavior on mobile
        if (window.innerWidth > 767) {
          header.classList.remove('header--hidden');
          ticking = false;
          return;
        }

        const y = window.scrollY;
        const delta = y - lastScrollY;

        if (y < 100) {
          header.classList.remove('header--hidden');
        } else if (delta > THRESHOLD) {
          header.classList.add('header--hidden');
        } else if (delta < -THRESHOLD) {
          header.classList.remove('header--hidden');
        }

        lastScrollY = y;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // Reset header on page navigation (short pages)
    function resetHeader() {
      if (header) {
        header.classList.remove('header--hidden');
        lastScrollY = 0;
      }
    }

    document.addEventListener('astro:page-load', resetHeader);
  }

  setupHeader();
  document.addEventListener('astro:after-swap', setupHeader);
</script>

<style>
  .site-header {
    padding: 3rem 0 2rem;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo:hover {
    text-decoration: none;
    opacity: 0.7;
  }

  .logo :global(.logo-container) {
    width: 42px;
    height: 28px;
  }

  .nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    font-family: 'Berkeley Mono', monospace;
    font-size: 1.4rem;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
  }

  .nav-link:hover {
    text-decoration: none;
    color: var(--color-heading);
  }

  .nav-link.active {
    color: var(--color-heading);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--color-heading);
    border-radius: 1px;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-muted);
    padding: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: color 0.2s;
  }

  .theme-toggle:hover {
    color: var(--color-text);
  }

  /* Show sun in dark mode, moon in light mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }

  @media (max-width: 767px) {
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 0;
      height: 64px;
      background: rgba(255, 255, 255, 0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
      z-index: 9999;
      display: flex;
      align-items: center;
      transition: transform 300ms ease;
      will-change: transform;
    }

    :global([data-theme="dark"]) .site-header {
      background: rgba(10, 10, 10, 0.88);
      box-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
    }

    .site-header.header--hidden {
      transform: translateY(-100%);
    }

    .header-inner {
      width: 100%;
      padding: 0 2rem;
    }

    .logo :global(.logo-container) {
      width: 36px;
      height: 24px;
    }

    .nav {
      gap: 0;
      height: 64px;
    }

    .nav-link {
      font-size: 1.3rem;
      display: flex;
      align-items: center;
      height: 64px;
      padding: 0 1rem;
    }

    .nav-link.active::after {
      bottom: 16px;
    }

    .theme-toggle {
      margin-left: 0.2rem;
      height: 64px;
      padding: 0 0.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header {
      transition: none !important;
    }
  }
</style>
