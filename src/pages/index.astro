---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('writing', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="John Milinovich">
  <h1>John Milinovich</h1>

  <ul class="facts">
    <li>Leading Generative AI Product at <a href="https://www.canva.com/">Canva</a>, where I helped build <a href="https://www.canva.com/newsroom/news/magic-studio/">Magic Studio</a> (<a href="https://time.com/7094550/canva-magic-studio/">Time's Best Inventions 2024</a>)</li>
    <li>Previously: founded <a href="https://techcrunch.com/2013/10/16/urx-ads/">URX</a> (acquired by Pinterest), led discovery at <a href="https://www.nytimes.com/2021/02/15/business/clubhouse.html">Clubhouse</a>, co-founded <a href="https://www.axios.com/2020/04/30/aesthetic-seed-funding-ai-brand-design">Aesthetic</a></li>
    <li>Early career at Google and Yahoo</li>
    <li>UCLA architecture &mdash; got hooked on code after seeing <a href="https://www.youtube.com/watch?v=_8DMEHxOLQE">Casey Reas</a> demo Processing.js</li>
    <li>Interested in AI-human collaboration, product craft, and building things</li>
  </ul>

  <section class="recent-writing">
    <h2>Writing</h2>
    {sortedPosts.map(post => (
      <PostCard title={post.data.title} date={post.data.date} slug={post.id} />
    ))}
  </section>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .facts {
    list-style: disc;
    padding-left: 2rem;
    font-size: 1.6rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 4rem;
  }

  .facts li {
    margin-bottom: 0.6rem;
  }

  .facts a {
    text-decoration: underline;
  }

  .recent-writing h2 {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }
</style>
