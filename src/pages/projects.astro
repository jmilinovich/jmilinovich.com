---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: "goal-md",
    description: "A goal-specification file for autonomous coding agents. Generalizes Karpathy's autoresearch to domains with constructed metrics.",
    url: "https://github.com/jmilinovich/goal-md",
    language: "Shell",
    stars: 49,
  },
  {
    name: "stylegen",
    description: "A Python library for generating cohesive Stable Diffusion prompts",
    url: "https://github.com/jmilinovich/stylegen",
    language: "Python",
    stars: 9,
  },
  {
    name: "agents.json",
    description: "Teaching websites how to talk to AI agents",
    url: "https://github.com/jmilinovich/agents.json",
    language: null,
    stars: 6,
  },
  {
    name: "browser-grid",
    description: "Tile Playwright browser windows in a grid for watching parallel tests run",
    url: "https://github.com/jmilinovich/browser-grid",
    language: "TypeScript",
    stars: 0,
  },
  {
    name: "comicgen",
    description: "AI comic book generator using Google Gemini with character consistency",
    url: "https://github.com/jmilinovich/comicgen",
    language: "Python",
    stars: 0,
  },
  {
    name: "worldmorph",
    description: "Multi-agent world simulations",
    url: "https://github.com/jmilinovich/worldmorph",
    language: "Python",
    stars: 0,
  },
];
---

<BaseLayout title="Projects - John Milinovich">
  <h1>Projects</h1>

  <ul class="projects-list">
    {projects.map(project => (
      <li class="project-item">
        <a href={project.url} target="_blank" rel="noopener" class="project-name">{project.name}</a>
        {project.language && <span class="project-lang">{project.language}</span>}
        {project.stars > 0 && <span class="project-stars">{project.stars}</span>}
        <p class="project-description">{project.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .projects-list {
    list-style: none;
    padding: 0;
  }

  .project-item {
    margin-bottom: 2rem;
  }

  .project-name {
    font-family: 'Berkeley Mono', monospace;
    font-size: 1.6rem;
    font-weight: 400;
    text-decoration: none;
  }

  .project-name:hover {
    text-decoration: underline;
  }

  .project-lang {
    font-size: 1.2rem;
    color: var(--color-muted);
    margin-left: 0.8rem;
  }

  .project-stars {
    font-size: 1.2rem;
    color: var(--color-muted);
    margin-left: 0.5rem;
  }

  .project-stars::before {
    content: "\2605 ";
  }

  .project-description {
    font-size: 1.4rem;
    color: var(--color-subtle);
    line-height: 1.5;
    margin-top: 0.3rem;
  }
</style>
